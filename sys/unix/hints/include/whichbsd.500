# 
#
.ifdef WHICHBSD
.undef WHICHBSD
.endif

OS!=uname -s

.if ${OS} == "FreeBSD"
WHICHBSD=FREEBSD
.elif ${OS} == "OpenBSD"
WHICHBSD=OPENBSD
.elif ${OS} == "NetBSD"
WHICHBSD=NETBSD
.else
WHICHBSD=OTHERBSD
.endif

# End of whichbsd.500 -PRE section
#=================================================================

